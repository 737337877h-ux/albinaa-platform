# انسخ إلى .env — لا يُرفع إلى Git أبدًا
NODE_ENV=development
PORT=3000
APP_VERSION=0.2.0

DATABASE_URL="postgresql://albinaa:albinaa_dev_only@localhost:5432/albinaa?schema=public"

# أسرار JWT — ولّد قيمًا عشوائية قوية (64+ حرفًا): openssl rand -hex 64
JWT_ACCESS_SECRET="CHANGE_ME_ACCESS_$(openssl rand -hex 32)"
JWT_REFRESH_SECRET="CHANGE_ME_REFRESH_DIFFERENT_SECRET"
JWT_ACCESS_TTL=900          # 15 دقيقة بالثواني
JWT_REFRESH_TTL=604800      # 7 أيام بالثواني

CORS_ORIGINS="http://localhost:5173,http://localhost:3001"
ADMIN_INITIAL_PASSWORD="ChangeMe!2026"
